  "tags": [
    "api-design",
    "rest",
    "graphql",
    "openapi",
    "sdk"
  ],
  "capabilities": [
    "openapi-generation",
    "graphql-schema-design",
    "sdk-scaffolding",
    "api-documentation",
    "versioning-strategy",
    "rate-limit-design"
  ],
  "difficulty": "intermediate",
  "persona_tags": [
    "developer"
  ],
  "config_schema": {
    "api_style": {
      "type": "string",
      "default": "rest",
      "enum": [
        "rest",
        "graphql",
        "grpc",
        "websocket"
      ]
    },
    "spec_format": {
      "type": "string",
      "default": "openapi-3.1",
      "enum": [
        "openapi-3.0",
        "openapi-3.1",
        "asyncapi"
      ]
    },
    "auth_scheme": {
      "type": "string",
      "default": "bearer",
      "enum": [
        "bearer",
        "api-key",
        "oauth2",
        "none"
      ]
    }
  },
  "name": "Prowlr Api Designer"
}
