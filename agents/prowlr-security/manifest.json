  "min_prowlrbot_version": "0.1.0",
  "category": "agents",
  "tags": [
    "security",
    "owasp",
    "penetration-testing",
    "dependency-scanning",
    "secret-detection"
  ],
  "capabilities": [
    "owasp-scanning",
    "dependency-audit",
    "secret-detection",
    "vulnerability-assessment",
    "compliance-checking",
    "security-hardening"
  ],
  "difficulty": "advanced",
  "persona_tags": [
    "developer"
  ],
  "config_schema": {
    "scan_scope": {
      "type": "string",
      "default": "full",
      "enum": [
        "full",
        "dependencies-only",
        "code-only",
        "config-only"
      ]
    },
    "owasp_version": {
      "type": "string",
      "default": "2025",
      "enum": [
        "2021",
        "2025"
      ]
    },
    "severity_threshold": {
      "type": "string",
      "default": "medium",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    }
  }
}
