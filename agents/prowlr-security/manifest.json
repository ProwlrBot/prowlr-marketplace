{
  "id": "agent-prowlr-security",
  "title": "Prowlr Security",
  "description": "Security auditor and penetration testing guide. OWASP compliance checks, dependency scanning, secret detection, and vulnerability assessment. The lock on your digital door.",
  "version": "1.0.0",
  "author": "ProwlrBot",
  "pricing_model": "free",
  "license": "Apache-2.0",
