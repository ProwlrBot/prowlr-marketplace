  "difficulty": "beginner",
  "persona_tags": [
    "creator",
    "freelancer",
    "business"
  ],
  "config_schema": {
    "tone": {
      "type": "string",
      "default": "professional",
      "enum": [
        "professional",
        "casual",
        "technical",
        "conversational",
        "academic"
      ]
    },
    "target_reading_level": {
      "type": "string",
      "default": "general",
      "enum": [
        "general",
        "technical",
        "academic",
        "simple"
      ]
    },
    "seo_enabled": {
      "type": "boolean",
      "default": true
    }
  }
