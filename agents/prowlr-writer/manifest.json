    "content-creation",
    "writing",
    "seo",
    "documentation",
    "copywriting"
  ],
  "capabilities": [
    "blog-generation",
    "seo-optimization",
    "tone-matching",
    "readability-analysis",
    "headline-generation",
    "content-repurposing"
